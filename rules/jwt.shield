rule jwt_algorithm_attack : jwt {
    meta:
        author      = "laraxaar"
        description = "JWT algorithm confusion and none algorithm attacks"
        severity    = "critical"

    target:
        $headers = request.headers
        $body = request.body
        $query = request.query

    strings:
        $none_alg = /"alg"\s*:\s*"none"/i
        $empty_sig = /eyJ[^.]+\.eyJ[^.]*\.[A-Za-z0-9_-]{0,2}$/
        $jwk_inject = /"jwk"\s*:\s*\{[^}]*"kty"\s*:/i

    condition:
        $none_alg or $empty_sig or $jwk_inject
}

// JKU/X5U can be legitimate in enterprise SSO (Auth0, Keycloak, Cognito).
// Separated from algorithm attacks with lower severity.
rule jwt_header_injection : jwt {
    meta:
        author      = "laraxaar"
        description = "JWT header URL injection — jku/x5u pointing to external key source"
        severity    = "medium"

    target:
        $headers = request.headers
        $body = request.body

    strings:
        $jku_redirect = /"jku"\s*:\s*"https?:\/\/[^"]+/i
        $x5u_attack = /"x5u"\s*:\s*"https?:\/\/[^"]+/i

    condition:
        $jku_redirect or $x5u_attack
}

rule jwt_key_confusion : jwt {
    meta:
        author      = "laraxaar"
        description = "JWT key ID manipulation and confusion attacks"
        severity    = "high"

    target:
        $headers = request.headers

    strings:
        $kid_traversal = /"kid"\s*:\s*".*\.{2}[\\\/].*"/i
        $kid_sql_inject = /"kid"\s*:\s*".*(union|select|or|and).*"/i
        $kid_command = /"kid"\s*:\s*".*[`;$|].*"/i
        $kid_null = /"kid"\s*:\s*(null|undefined|false)/i
        $kid_array = /"kid"\s*:\s*\[/i

    condition:
        $kid_traversal or $kid_sql_inject or $kid_command or $kid_null or $kid_array
}
