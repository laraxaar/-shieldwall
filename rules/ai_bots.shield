rule ai_web_scraper : botnet {
    meta:
        author      = "laraxaar"
        description = "Detects aggressive AI Web Scrapers, LLM crawlers, and content thieves"
        severity    = "high"
        category    = "botnet"

    target:
        $user_agent = request.useragent

    strings:
        $openai    = /(GPTBot|ChatGPT-User|OAI-SearchBot)/i
        $anthropic = /(ClaudeBot|Claude-Web)/i
        $google    = /(Google-Extended|Gemini)/i
        $misc_ai   = /(CCBot|Omgili|FacebookBot|Diffbot|Bytespider|PerplexityBot|PetalBot|Amazonbot|Cohere-ai)/i
        $generic   = /(AI-scraper|LLM-crawler|GPT-crawling)/i

    condition:
        $openai or $anthropic or $google or $misc_ai or $generic
}
